# ─── GCP / Secret Manager ────────────────────────────────────────────────────
# Set GCP_PROJECT_ID to enable Secret Manager lookups.
# Omit it to fall back to the explicit env vars below (recommended for local dev).
GCP_PROJECT_ID=

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION_STRING=mongodb://localhost:27017
DB_NAME=weather

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_key_for_local_development_only
JWT_EXPIRATION=3600000
JWT_AUDIENCE=weatherify-app
JWT_ISSUER=weatherify-backend
JWT_REALM=jwt-realm

# ─── Weather API (OpenWeatherMap) ─────────────────────────────────────────────
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_URL=https://api.openweathermap.org/data/3.0/onecall
AIR_POLLUTION_URL=https://api.openweathermap.org/data/2.5/air_pollution

# ─── Razorpay Payments ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Weatherify

# ─── Firebase Push Notifications ─────────────────────────────────────────────
# Either set this to the path of your serviceAccountKey.json file,
# or configure the firebase-service-account-key secret in GCP Secret Manager.
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json

# ─── Redis ────────────────────────────────────────────────────────────────────
# Leave blank to disable Redis caching (in-memory fallback used instead).
REDIS_URL=redis://localhost:6379

# ─── Analytics (GA4) ──────────────────────────────────────────────────────────
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your_ga4_api_secret_here
GA_ENABLED=false

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
